@{
    ViewData["Title"] = "No Users Found";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="hb-card text-center">
            <div class="hb-card-body py-5">
                <i class="bi bi-people text-muted mb-3" style="font-size: 4rem;"></i>
                <h3 class="text-warning mb-3">No Users Available</h3>
                <p class="text-muted mb-4">There are currently no users in the system to view as a regular user.</p>
                <a asp-controller="Admin" asp-action="CreateUser" class="btn btn-warning">Go to Admin and Create a User</a>
            </div>
        </div>
    </div>
</div>
