@{
    ViewData["Title"] = "Contact Us";
}

<div class="row mt-4">
    <div class="col-md-6 mb-4">
        <div class="hb-card h-100">
            <div class="hb-card-header">
                <h2>Get In Touch</h2>
            </div>
            <div class="hb-card-body">
                <p>If you have any questions or need support, our team is ready to help 24/7.</p>
                
                <ul class="list-unstyled mt-4">
                    <li class="mb-3"><i class="bi bi-envelope-fill text-warning me-2"></i> <strong>Email:</strong> support@horizonbetting.demo</li>
                    <li class="mb-3"><i class="bi bi-telephone-fill text-warning me-2"></i> <strong>Phone:</strong> +1 (800) 555-0199</li>
                    <li class="mb-3"><i class="bi bi-geo-alt-fill text-warning me-2"></i> <strong>Address:</strong> 777 Jackpot Avenue, Casino City</li>
                </ul>

                <h5 class="text-warning mt-4 mb-3">Follow Us</h5>
                <div class="d-flex gap-3">
                    <a href="https://facebook.com" target="_blank" class="text-light fs-4"><i class="bi bi-facebook"></i></a>
                    <a href="https://instagram.com" target="_blank" class="text-light fs-4"><i class="bi bi-instagram"></i></a>
                    <a href="https://twitter.com" target="_blank" class="text-light fs-4"><i class="bi bi-twitter-x"></i></a>
                    <a href="https://linkedin.com" target="_blank" class="text-light fs-4"><i class="bi bi-linkedin"></i></a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="hb-card h-100">
            <div class="hb-card-header">
                <h2>Send a Message</h2>
            </div>
            <div class="hb-card-body">
                <form>
                    <div class="mb-3">
                        <label for="name" class="form-label">Full Name</label>
                        <input type="text" class="form-control" id="name" placeholder="John Doe">
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email Address</label>
                        <input type="email" class="form-control" id="email" placeholder="john@example.com">
                    </div>
                    <div class="mb-3">
                        <label for="subject" class="form-label">Subject</label>
                        <input type="text" class="form-control" id="subject" placeholder="How can we help?">
                    </div>
                    <div class="mb-3">
                        <label for="message" class="form-label">Message</label>
                        <textarea class="form-control" id="message" rows="4" placeholder="Your message here..."></textarea>
                    </div>
                    <button type="button" class="btn btn-warning w-100" onclick="alert('Thank you! Your message has been sent.')">Send Message</button>
                </form>
            </div>
        </div>
    </div>
</div>
