@model HorizonBetting.Models.Account

@{
    ViewData["Title"] = "Account Details";
}

<div class="mb-3 d-flex justify-content-between align-items-center">
    <a asp-action="UserDetails" asp-route-id="@Model.UserId" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back to User Profile</a>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="hb-card">
            <div class="hb-card-header">
                Account Summary
            </div>
            <div class="hb-card-body text-center">
                <p class="text-muted mb-1">Account Number</p>
                <h4 class="mb-4">@Model.AccountNumber</h4>
                
                <p class="text-muted mb-1">Outstanding Balance</p>
                <h2 class="@(Model.OutstandingBalance < 0 ? "text-danger" : "text-success") fw-bolder mb-4">
                    R @Model.OutstandingBalance.ToString("0.00")
                </h2>
                
                <p class="text-muted mb-1">Account Holder</p>
                <p class="fw-bold">@Model.User?.FirstName @Model.User?.Surname</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="hb-card">
            <div class="hb-card-header d-flex justify-content-between align-items-center">
                <span>Transactions</span>
                <a asp-action="CreateTransaction" asp-route-accountId="@Model.Id" class="btn btn-warning btn-sm"><i class="bi bi-plus-circle me-1"></i> Capture Transaction</a>
            </div>
            <div class="hb-card-body">
                @if (Model.Transactions.Any())
                {
                    <div class="table-responsive">
                        <table class="table hb-table mb-0">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Amount</th>
                                    <th>Captured On</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in Model.Transactions.OrderByDescending(x => x.TransactionDate))
                                {
                                    <tr>
                                        <td>@t.TransactionDate.ToShortDateString()</td>
                                        <td>
                                            @if (t.Type == HorizonBetting.Models.TransactionType.Debit)
                                            {
                                                <span class="badge bg-danger text-white">Debit</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success text-white">Credit</span>
                                            }
                                        </td>
                                        <td class="fw-bold">R @t.Amount.ToString("0.00")</td>
                                        <td class="text-muted small">@t.CaptureDate.ToString("g")</td>
                                        <td class="text-end">
                                            <a asp-action="EditTransaction" asp-route-id="@t.Id" class="btn btn-sm btn-primary"><i class="bi bi-pencil"></i> Edit</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center mb-0">No transactions recorded yet.</p>
                }
            </div>
        </div>
    </div>
</div>
