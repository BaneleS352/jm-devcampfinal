@model HorizonBetting.Models.Account

@{
    ViewData["Title"] = "Create Account";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="hb-card">
            <div class="hb-card-header">
                <h3>Create New Account</h3>
            </div>
            <div class="hb-card-body">
                <form asp-action="CreateAccount">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="UserId" />
                    
                    <div class="mb-4">
                        <label asp-for="AccountNumber" class="form-label"></label>
                        <input asp-for="AccountNumber" class="form-control" />
                        <span asp-validation-for="AccountNumber" class="text-danger"></span>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning"><i class="bi bi-save me-1"></i> Create Account</button>
                        <a asp-action="UserDetails" asp-route-id="@Model.UserId" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
