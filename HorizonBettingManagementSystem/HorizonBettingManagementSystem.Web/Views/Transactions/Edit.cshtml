@model HorizonBettingManagementSystem.Web.Models.Transaction

<div class="container mt-4">

    <h2>Edit Transaction</h2>

    <form method="post" action="/Transactions/Edit">

        <!-- CRITICAL -->
        <input type="hidden" name="TransactionId" value="@Model.TransactionId" />
        <input type="hidden" name="AccountId" value="@Model.AccountId" />
        <input type="hidden" name="CaptureDate" value="@Model.CaptureDate" />

        <div class="mb-3">
            <label>Transaction Type</label>
            <select name="TransactionType" class="form-control">
                <option value="Credit" selected="@(Model.TransactionType == "Credit")">Credit</option>
                <option value="Debit" selected="@(Model.TransactionType == "Debit")">Debit</option>
                <option value="Voucher" selected="@(Model.TransactionType == "Voucher")">Voucher</option>
            </select>
        </div>

        <div class="mb-3">
            <label>Amount</label>
            <input name="Amount" value="@Model.Amount" type="number" step="0.01" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Transaction Date</label>
            <input name="TransactionDate"
                   value="@Model.TransactionDate.ToString("yyyy-MM-ddTHH:mm")"
                   type="datetime-local"
                   class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Save Changes</button>

        <a href="/Accounts/Details/@Model.AccountId" class="btn btn-secondary">Back</a>

    </form>

</div>