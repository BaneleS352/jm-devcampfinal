@model HorizonBettingManagementSystem.Web.Models.Transaction

<div class="container mt-4">

    <h3>Delete Transaction</h3>

    <p>Are you sure you want to delete this transaction?</p>

    <div class="mb-3">
        <strong>Type:</strong> @Model.TransactionType
    </div>

    <div class="mb-3">
        <strong>Amount:</strong> @Model.Amount
    </div>

    <div class="mb-3">
        <strong>Date:</strong> @Model.TransactionDate.ToString("yyyy-MM-dd HH:mm")
    </div>

    <form method="post" action="/Transactions/DeleteConfirmed">

        <!-- MUST MATCH 'id' -->
        <input type="hidden" name="id" value="@Model.TransactionId" />

        <button type="submit" class="btn btn-danger">Delete</button>

        <a href="/Accounts/Details/@Model.AccountId" class="btn btn-secondary">
            Cancel
        </a>

    </form>

</div>