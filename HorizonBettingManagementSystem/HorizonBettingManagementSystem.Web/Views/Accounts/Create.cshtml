@model HorizonBettingManagementSystem.Web.Models.Account

<div class="container mt-4">

    <h2>Create Account</h2>

    <form method="post" action="/Accounts/Create">

        <!-- REQUIRED -->
        <input type="hidden" name="ClientId" value="@ViewBag.ClientId" />

        <div class="mb-3">
            <label>Account Number</label>
            <input name="AccountNumber" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Initial Balance</label>
            <input name="Balance" type="number" step="0.01" class="form-control" />
        </div>

        <!-- Won't rely on user for this -->
        <input type="hidden" name="IsClosed" value="false" />

        <button type="submit" class="btn btn-primary">Create</button>
        <a href="/Clients/Details/@ViewBag.ClientId" class="btn btn-secondary">Back</a>

    </form>

</div>