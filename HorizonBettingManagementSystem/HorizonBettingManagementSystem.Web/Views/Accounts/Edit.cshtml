@model HorizonBettingManagementSystem.Web.Models.Account

<div class="container mt-4">

    <h2>Edit Account</h2>

    <form method="post" action="/Accounts/Edit">

        <!-- CRITICAL FIELDS -->
        <input type="hidden" name="AccountId" value="@Model.AccountId" />
        <input type="hidden" name="ClientId" value="@Model.ClientId" />
        <input type="hidden" name="CreatedDate" value="@Model.CreatedDate" />

        <div class="mb-3">
            <label>Account Number</label>
            <input name="AccountNumber" value="@Model.AccountNumber" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Balance</label>
            <input name="Balance" value="@Model.Balance" type="number" step="0.01" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Status</label>
            <select name="IsClosed" class="form-control">
                <option value="false" selected="@(Model.IsClosed == false)">Active</option>
                <option value="true" selected="@(Model.IsClosed == true)">Closed</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/Accounts/Details/@Model.AccountId" class="btn btn-secondary">Back</a>

    </form>

</div>