@model List<HorizonBettingManagementSystem.Web.Models.Client>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="page-title">Clients</h2>
        <a href="/Clients/Create" class="btn btn-primary">+ New Client</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">

            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID Number</th>
                        <th>Name</th>
                        <th>Accounts</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.IdNumber</td>
                            <td>@item.FirstName @item.LastName</td>
                            <td>@(item.Accounts != null ? item.Accounts.Count : 0)</td>
                            <td>@item.CreatedDate.ToString("yyyy-MM-dd")</td>

                            <td class="text-end">
                                <a href="/Clients/Details/@item.ClientId" class="btn btn-sm btn-outline-info">View</a>
                                <a href="/Clients/Edit/@item.ClientId" class="btn btn-sm btn-outline-warning">Edit</a>
                                <a href="/Clients/Delete/@item.ClientId" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>