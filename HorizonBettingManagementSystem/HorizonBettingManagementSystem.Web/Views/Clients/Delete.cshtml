@model HorizonBettingManagementSystem.Web.Models.Client

<div class="container mt-4">

    <h3>Are you sure you want to delete this client?</h3>

    <p><strong>@Model.FirstName @Model.LastName</strong></p>

    <form method="post" action="/Clients/DeleteConfirmed">

        <input type="hidden" name="id" value="@Model.ClientId" />

        <button type="submit" class="btn btn-danger">Delete</button>
        <a href="/Clients" class="btn btn-secondary">Cancel</a>

    </form>

</div>